{
  "version": "1.1.0",
  "kind": "Node",
  "spec": {
    "nodes": [
      {
        "recurrence": "Normal",
        "timeout": 0,
        "instanceMode": "T+1",
        "rerunMode": "Allowed",
        "rerunTimes": 3,
        "rerunInterval": 180000,
        "datasource": {
          "name": "{{datasource_name}}",
          "type": "odps"
        },
        "script": {
          "path": "{{script_path}}",
          "language": "sql",
          "runtime": {
            "command": "ODPS_SQL"
          },
          "content": "{{sql_content}}",
          "parameters": [
            {
              "name": "bizdate",
              "artifactType": "Variable",
              "scope": "NodeParameter",
              "type": "System",
              "value": "$[yyyymmdd-1]"
            }
          ]
        },
        "trigger": {
          "type": "Scheduler",
          "cron": "{{cron_expression}}",
          "startTime": "1970-01-01 00:00:00",
          "endTime": "9999-01-01 00:00:00",
          "timezone": "Asia/Shanghai"
        },
        "runtimeResource": {
          "resourceGroup": "{{resource_group}}"
        },
        "name": "{{node_name}}",
        "inputs": {
          "nodeOutputs": [
            {
              "data": "{{input_dependency}}",
              "artifactType": "NodeOutput"
            }
          ]
        },
        "outputs": {
          "nodeOutputs": [
            {
              "data": "{{output_name}}",
              "artifactType": "NodeOutput"
            }
          ]
        }
      }
    ]
  }
}
