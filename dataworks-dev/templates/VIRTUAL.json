{
  "version": "1.1.0",
  "kind": "Node",
  "spec": {
    "nodes": [
      {
        "recurrence": "Normal",
        "timeout": 0,
        "instanceMode": "T+1",
        "rerunMode": "Allowed",
        "rerunTimes": 0,
        "rerunInterval": 0,
        "script": {
          "path": "{{script_path}}",
          "runtime": {
            "command": "VIRTUAL"
          },
          "content": ""
        },
        "trigger": {
          "type": "Scheduler",
          "cron": "{{cron_expression}}",
          "startTime": "1970-01-01 00:00:00",
          "endTime": "9999-01-01 00:00:00",
          "timezone": "Asia/Shanghai"
        },
        "name": "{{node_name}}",
        "outputs": {
          "nodeOutputs": [
            {
              "data": "{{output_name}}",
              "artifactType": "NodeOutput"
            }
          ]
        }
      }
    ]
  }
}
